NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Canonical public URL of this app (no trailing slash). Used for Vapi webhooks, email redirects, etc.
NEXT_PUBLIC_APP_URL=https://fieldai-evan.vercel.app
# Optional: same role as NEXT_PUBLIC_APP_URL if you only set one
NEXT_PUBLIC_SITE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# OpenAI: used by POST /api/vapi/webhook to turn transcripts into dispatch fields
OPENAI_API_KEY=
# Optional; default gpt-4o-mini
OPENAI_MODEL=

# Optional: when set, generic POST /api/calls/webhook requires Authorization: Bearer <secret> or X-Webhook-Secret
CALLS_WEBHOOK_SECRET=

# Required for POST /api/vapi/webhook (Vapi Server URL). Use a long random string; match Vapi Custom Credential token.
VAPI_WEBHOOK_SECRET=
